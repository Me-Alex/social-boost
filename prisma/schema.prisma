// SocialBoost - Social Media Growth Platform Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  password      String?
  credits       Int          @default(100)
  plan          String       @default("free")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  campaigns     Campaign[]
}

model Campaign {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  platform        Platform        // youtube or instagram
  serviceType     ServiceType     // views, subscribers, likes, comments, followers
  targetUrl       String
  targetId        String          // video ID, post URL, etc.
  quantity        Int             @default(0)
  completedCount  Int             @default(0)
  status          String          @default("pending")
  speed          String          @default("normal") // slow, normal, fast
  geoTarget       String?         // country code targeting
  dailyLimit      Int?            // daily delivery limit
  creditsSpent    Int             @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum Platform {
  youtube
  instagram
}

enum ServiceType {
  views
  subscribers
  likes
  comments
  followers
  reels_views
  story_views
}

enum CampaignStatus {
  pending
  active
  paused
  completed
  cancelled
  failed
}